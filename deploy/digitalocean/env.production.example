ACME_EMAIL=admin@example.com

YOLOBOX_APP_HOST=app.yolobox.dev
YOLOBOX_API_HOST=api.yolobox.dev
YOLOBOX_PREVIEW_BASE_DOMAIN=hosted.yolobox.dev
YOLOBOX_PREVIEW_TARGET_PORT=80
YOLOBOX_APP_URL=https://app.yolobox.dev
YOLOBOX_API_URL=https://api.yolobox.dev
BETTER_AUTH_URL=https://api.yolobox.dev/v1/auth
BETTER_AUTH_TRUSTED_ORIGINS=https://app.yolobox.dev,https://api.yolobox.dev
YOLOBOX_BACKEND_CORS_ORIGINS=https://app.yolobox.dev,https://api.yolobox.dev
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-bytes

YOLOBOX_BACKEND_PROVIDER=digitalocean
DIGITALOCEAN_ACCESS_TOKEN=dop_v1_example
DIGITALOCEAN_REGION=nyc3
DIGITALOCEAN_SIZE=s-2vcpu-4gb-amd
DIGITALOCEAN_IMAGE=ubuntu-24-04-x64
DIGITALOCEAN_TAGS=yolobox
YOLOBOX_REMOTE_IMAGE=
YOLOBOX_REMOTE_IMAGE_REF=
YOLOBOX_REMOTE_IMAGE_NAME=
YOLOBOX_REMOTE_IMAGE_BUILT_AT=
DIGITALOCEAN_VPC_UUID=

# Image-builder SSH only. Normal user VMs use yolobox SSH certificates, not
# DigitalOcean account SSH keys.
DIGITALOCEAN_SSH_KEYS=
YOLOBOX_IMAGE_BUILDER_SSH_PUBLIC_KEY=

YOLOBOX_BACKUP_RETENTION_DAYS=14
